{
  app: {
    signingConfigs: [],
    products: [
      {
        name: 'default',
        signingConfig: 'default',
        compatibleSdkVersion: '5.1.0(18)',
        runtimeOS: 'HarmonyOS',
      },
      {
        name: 'apple',
        signingConfig: 'appledebug',
        compatibleSdkVersion: '5.1.0(18)',
        runtimeOS: 'HarmonyOS',
        bundleName: 'com.example.apple.ohos',
        bundleType: 'app',
        targetSdkVersion: '5.1.0(18)',
        buildOption: {
          strictMode: {
            caseSensitiveCheck: true,
            useNormalizedOHMUrl: true,
          },
        },
        versionName: '1.0.2',
      },
      {
        name: 'banana',
        signingConfig: 'banana',
        compatibleSdkVersion: '5.1.0(18)',
        runtimeOS: 'HarmonyOS',
        bundleName: 'com.example.banana.ohos',
        bundleType: 'app',
      },
    ],
    buildModeSet: [
      {
        name: 'debug',
      },
      {
        name: 'profile',
      },
      {
        name: 'release',
      },
    ],
  },
  modules: [
    {
      name: 'entry',
      srcPath: './entry',
      targets: [
        {
          name: 'default',
          applyToProducts: [
            'default',
          ],
        },
        {
          name: 'apple',
          applyToProducts: [
            'apple',
          ],
        },
        {
          name: 'banana',
          applyToProducts: [
            'banana',
          ],
        },
      ],
    },
  ],
}